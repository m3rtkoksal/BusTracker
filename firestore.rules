rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function groupData(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data;
    }

    function isGroupDriver(groupId) {
      return isSignedIn() && groupData(groupId).driverMemberID == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.auth.uid == memberId
          && request.resource.data.userID == request.auth.uid;
        allow update: if isSignedIn()
          && (request.auth.uid == memberId || isGroupDriver(groupId));
        allow delete: if isSignedIn()
          && (request.auth.uid == memberId || isGroupDriver(groupId));
      }

      match /live/{document=**} {
        allow read, write: if isSignedIn();
      }

      match /attendance/{date} {
        allow read, write: if isSignedIn();
      }

      match /tripEvents/{eventId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
      }

      match /morningPickups/{memberId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn()
          && request.resource.data.memberID == memberId;
        allow delete: if isSignedIn()
          && (request.auth.uid == memberId || isGroupDriver(groupId));
      }

      match /tripTelemetry/{telemetryId} {
        allow read, write: if isSignedIn();
      }

      match /tripActivity/{activityDocId} {
        allow read, write: if isSignedIn();
      }

      match /routeHistory/{tripId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isGroupDriver(groupId);
        allow update, delete: if false;
      }

      match /canonicalRoutes/{sessionId} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }
  }
}
