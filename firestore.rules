rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function groupData(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data;
    }

    function isGroupDriver(groupId) {
      return isSignedIn() && groupData(groupId).driverMemberID == request.auth.uid;
    }

    function subscriptionFieldsUnchanged() {
      return (!('subscriptionStartDate' in request.resource.data)
          || request.resource.data.subscriptionStartDate == resource.data.subscriptionStartDate)
        && (!('subscriptionEndDate' in request.resource.data)
          || request.resource.data.subscriptionEndDate == resource.data.subscriptionEndDate)
        && (!('subscriptionUpdatedAt' in request.resource.data)
          || request.resource.data.subscriptionUpdatedAt == resource.data.subscriptionUpdatedAt);
    }

    function poolServerFieldsUnchanged() {
      return (!('poolCollected' in request.resource.data)
          || request.resource.data.poolCollected == resource.data.poolCollected)
        && (!('poolUpdatedAt' in request.resource.data)
          || request.resource.data.poolUpdatedAt == resource.data.poolUpdatedAt);
    }

    function poolModeUpdateValid() {
      return request.resource.data.poolMode in ['monthly', 'annual']
        && request.resource.data.poolTarget is int
        && (
          (request.resource.data.poolMode == 'monthly' && request.resource.data.poolTarget == 99)
          || (request.resource.data.poolMode == 'annual' && request.resource.data.poolTarget == 1000)
        );
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && subscriptionFieldsUnchanged()
        && poolServerFieldsUnchanged()
        && (
          !('poolMode' in request.resource.data)
          || poolModeUpdateValid()
        );

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.auth.uid == memberId
          && request.resource.data.userID == request.auth.uid;
        allow update: if isSignedIn()
          && (request.auth.uid == memberId || isGroupDriver(groupId));
        allow delete: if isSignedIn()
          && (request.auth.uid == memberId || isGroupDriver(groupId));
      }

      match /live/{document=**} {
        allow read, write: if isSignedIn();
      }

      match /attendance/{date} {
        allow read, write: if isSignedIn();
      }

      match /tripEvents/{eventId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
      }

      match /delayNotices/{serviceKey} {
        allow read: if isSignedIn();
        allow write: if false;
      }

      match /morningPickups/{memberId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn()
          && request.resource.data.memberID == memberId;
        allow delete: if isSignedIn()
          && (request.auth.uid == memberId || isGroupDriver(groupId));
      }

      match /tripTelemetry/{telemetryId} {
        allow read, write: if isSignedIn();
      }

      match /tripActivity/{activityDocId} {
        allow read, write: if isSignedIn();
      }

      match /routeHistory/{tripId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isGroupDriver(groupId);
        allow update, delete: if false;
      }

      match /canonicalRoutes/{sessionId} {
        allow read: if isSignedIn();
        allow write: if false;
      }

      match /subscriptionPayments/{paymentId} {
        allow read, write: if false;
      }

      match /poolIAPTransactions/{transactionId} {
        allow read, write: if false;
      }
    }

    match /subscriptionPaymentIndex/{conversationId} {
      allow read, write: if false;
    }
  }
}
